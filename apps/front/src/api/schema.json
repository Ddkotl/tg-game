  "info": {
    "title": "TG Game API",
    "description": "API for Telegram Game",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "ApiResponseDto": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object"
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "data",
          "error"
        ]
      },
      "UpgradeStatsDto": {
        "type": "object",
        "properties": {
          "stat": {
            "type": "string",
            "enum": [
              "strength",
              "defense"
            ]
          },
          "points": {
            "type": "number",
            "description": "Number of points to add"
          }
        },
        "required": [
          "stat",
          "points"
        ]
      },
      "AttackDto": {
        "type": "object",
        "properties": {
          "attackerId": {
            "type": "string",
            "description": "Attacker player id"
          },
          "defenderId": {
            "type": "string",
            "description": "Defender player id"
          }
        },
        "required": [
          "attackerId",
          "defenderId"
        ]
      },
      "TelegramAuthDto": {
        "type": "object",
        "properties": {
          "initData": {
            "type": "string",
            "description": "Telegram Web App initData string"
          }
        },
        "required": [
          "initData"
        ]
      }
    }
  }
